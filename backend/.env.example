# ===== Server =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ===== Database (SQLite for Phase 1, Postgres-ready) =====
DATABASE_URL=sqlite+aiosqlite:///./data/jarvis.db

# ===== Ollama =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# ===== Whisper (STT) =====
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ===== Piper (TTS) =====
PIPER_BINARY_PATH=piper
PIPER_VOICE_MODEL_PATH=./voices/en_US-amy-medium.onnx
PIPER_VOICE_CONFIG_PATH=./voices/en_US-amy-medium.onnx.json

# ===== Wake Word =====
WAKE_WORD=hey jarvis
WAKE_WORD_SIMILARITY_THRESHOLD=0.72

# ===== Memory =====
MAX_CONTEXT_MESSAGES=20
